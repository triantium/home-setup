# my global config
global:
  scrape_interval:     120s # Set the scrape interval to every 15 seconds. Default is every 1 minute.
  evaluation_interval: 360s # Evaluate rules every 15 seconds. The default is every 1 minute.
  # scrape_timeout is set to the global default (10s).
# Alertmanager configuration
# Load and evaluate rules in this file every 'evaluation_interval' seconds.
rule_files:
  - 'alert.rules'
  - 'restic.rules'

# alert
alerting:
  alertmanagers:
  - scheme:            http
    static_configs:
    - targets:
      - "alertmanager:9093"
# A scrape configuration containing exactly one endpoint to scrape:
# Here it's Prometheus itself.
scrape_configs:
  # The job name is added as a label `job=<job_name>` to any timeseries scraped from this config.
  - job_name: 'prometheus'
    # metrics_path defaults to '/metrics'
    # scheme defaults to 'http'.
    static_configs:
    - targets:         ['localhost:9090']
  - job_name: 'vector'
    scrape_interval: 30s
    static_configs:
    - targets:
      - 'gloin.fritz.box:9598'
      - 'heimdall.fritz.box:9598'
      - 'nas.fritz.box:9598'
      labels:
        app: 'vector'
  - job_name:          'tmp-nodes'
    scrape_interval: 20s
    static_configs:
    - targets:
      - 'dori.fritz.box:9100'
      - 'jormundgar.fritz.box:9100'
      - 'berserker.fritz.box:9100'
      - 'octopi.fritz.box:9100'
  - job_name: 'fw-nodes'
    scrape_interval: 10s
    static_configs:
      - targets:
          - 'display-02.taila24d4b.ts.net:9100'
  - job_name:          'perm-nodes'
    scrape_interval: 10s
    static_configs:
    - targets:
      - 'gloin.fritz.box:9100'
      - 'inkycal.fritz.box:9100'
      - 'nas.fritz.box:9100'
      - 'heimdall.fritz.box:9100'
      - 'display-02.taila24d4b.ts.net:9100'
  - job_name: 'tmp-windows'
    scrape_interval: 45s
    static_configs:
      - targets:
          - 'odin.fritz.box:9182'
  - job_name: 'fritzbox'
    scrape_interval:   120s
    scrape_timeout: 30s
    static_configs:
    - targets:
       - 'gloin.fritz.box:9042'
  - job_name: 'restic'
    metrics_path: "/"
    scrape_interval:   360s
    scrape_timeout: 30s
    static_configs:
      - targets:
         - 'gloin.fritz.box:8001'
  - job_name:          'navidrome'
    scheme:            'https'
    #basic_auth:
    #    username:     'admin'
    #    password:     'xxx'
    metrics_path:      '/navidrome/metrics'
    static_configs:
    - targets:         ['triantium.ddns.net']
      labels:
        app:           'navidrome'
  - job_name:          'miniflux'
    scheme:            'https'
    #basic_auth:
    #    username:     'admin'
    #    password:     'xxx'
    metrics_path:      '/miniflux/metrics'
    static_configs:
    - targets:         ['triantium.ddns.net']
      labels:
        app:           'miniflux'
  - job_name:          'grafana'
    scheme:            'http'
    metrics_path:      '/metrics'
    static_configs:
    - targets:         ['grafana:3000']
      labels:
        app:           'grafana'
  - job_name:          'influxdb'
    scheme:            'http'
    metrics_path:      '/metrics'
    static_configs:
    - targets:         ['nas.fritz.box:8086']
      labels:
        app:           'influxdb'
  - job_name: 'paperless'
    scheme: 'http'
    metrics_path: '/metrics'
    scrape_interval: 360s
    static_configs:
      - targets: [ 'nas.fritz.box:8084' ]
        labels:
          app: 'paperless'
  - job_name: 'mosquitto'
    scheme: 'http'
    metrics_path: '/metrics'
    scrape_interval: 50s
    static_configs:
      - targets: [ 'nas.fritz.box:9234' ]
        labels:
          app: 'mosquitto'
  - job_name:          'gitea'
    scheme:            'https'
    metrics_path:      '/metrics'
    static_configs:
    - targets:         ['git.geekinbusiness.de']
      labels:
        app:           'gitea'
  - job_name:          'alertmanager'
    scheme:            'http'
    metrics_path:      '/metrics'
    static_configs:
    - targets:         ['alertmanager:9093']
      labels:
        app:           'alertmanager'
  - job_name: 'spoolman'
    scrape_interval: 30s
    metrics_path: 'metrics'
    static_configs:
      - targets: [ 'octopi.fritz.box:7912' ]
  - job_name:          'blackbox'
    metrics_path:      /probe
    params:
      module:          [http_2xx]  # Look for a HTTP 200 response.
    static_configs:
      - targets:
        - https://triantium.ddns.net
        - https://triantium.ddns.net/miniflux/
        - https://triantium.ddns.net/navidrome/app
        - https://geekinbusiness.de
        - https://git.geekinbusiness.de
        - https://owncloud.geekinbusiness.de
        - https://nexus.geekinbusiness.de
        - https://jenkins.geekinbusiness.de/login
        - https://geekinbusiness.de:10000
        - https://mail.geekinbusiness.de:20000
    relabel_configs:
      - source_labels: [__address__]
        target_label:  __param_target
      - source_labels: [__param_target]
        target_label:  instance
      - target_label:  __address__
        replacement:   blackbox:9115
  - job_name:          'tls-blackbox'
    metrics_path:      /probe
    params:
      module:          [tcp_connect_tls]
    static_configs:
      - targets:
        - imap.geekinbusiness.de:993
    relabel_configs:
      - source_labels: [__address__]
        target_label:  __param_target
      - source_labels: [__param_target]
        target_label:  instance
      - target_label:  __address__
        replacement:   blackbox:9115
