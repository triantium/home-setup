  - job_name:          'smtp-blackbox'
    metrics_path:      /probe
    params:
      module:          [smtp_starttls]
    static_configs:
      - targets:
        - smtp.geekinbusiness.de:587
        #- smtp.fablab-donautal.de:587
    relabel_configs:
      - source_labels: [__address__]
        target_label:  __param_target
      - source_labels: [__param_target]
        target_label:  instance
      - target_label:  __address__
        replacement:   blackbox:9115
  - job_name:          'ssh-blackbox'
    metrics_path:      /probe
    params:
      module:          [ssh_banner]
    static_configs:
      - targets:
        #- triantium.ddns.net:22
        - geekinbusiness.de:22
        - 195.201.242.34:22
        - 138.201.17.10:22
    relabel_configs:
      - source_labels: [__address__]
        target_label:  __param_target
      - source_labels: [__param_target]
        target_label:  instance
      - target_label:  __address__
        replacement:   blackbox:9115
  - job_name:          'blackbox-external'
    metrics_path:      /probe
    params:
      module:          [http_2xx]  # Look for a HTTP 200 response.
    static_configs:
      - targets:
        - https://github.com/
    relabel_configs:
      - source_labels: [__address__]
        target_label:  __param_target
      - source_labels: [__param_target]
        target_label:  instance
      - target_label:  __address__
        replacement:   blackbox:9115
  - job_name: 'pushgateway'
    honor_labels: true
    scrape_interval: 30s
    static_configs:
      - targets: ['pushgateway:9091']
        labels:
          app: 'pushgateway'

  ## gather the metrics of json_exporter application itself
  - job_name: json_exporter
    # scrape_interval:   30s
    static_configs:
      - targets:
          ## Location of the json exporter's real <hostname>:<port>
          - json-exporter:7979 # equivalent to "localhost:7979"

    ## gather the metrics from third party json sources, via the json exporter
  - job_name: json
    metrics_path: /probe
    scrape_interval:   30s
    params:
      module: [ default ]
    static_configs:
      - targets:
          - http://meshtastic.fritz.box/json/report
    relabel_configs:
      - source_labels: [ __address__ ]
        target_label: __param_target
      - source_labels: [ __param_target ]
        target_label: instance
      - target_label: __address__
        ## Location of the json exporter's real <hostname>:<port>
        replacement: json-exporter:7979 # equivalent to "localhost:7979"
