#    metrics_path:      /probe
#    params:
#      module:          [imap_starttls]
#    static_configs:
#      - targets:
#        - imap.fablab-donautal.de:143
#    relabel_configs:
#      - source_labels: [__address__]
#        target_label:  __param_target
#      - source_labels: [__param_target]
#        target_label:  instance
