global:
  # The smarthost and SMTP sender used for mail notifications.
  smtp_smarthost:     'smtp.mailbox.org:465'
  smtp_from:          'alertmanager@triantium.de'
  smtp_auth_username: 'triantium@mailbox.org'
  smtp_auth_password: '{{ smtp_password }}'
  smtp_require_tls:   false
  resolve_timeout:    4h

route:
  group_by:           ['alertname']
  group_wait:         10s
  group_interval:     10s
  repeat_interval:    24h
  receiver:           'email'
receivers:
- name:               'email'
  email_configs:
  - to:               'alerts@triantium.de'
inhibit_rules:
  - source_match:
      severity:       'critical'
    target_match:
      severity:       'warning'
    equal:            ['alertname', 'dev', 'instance']
