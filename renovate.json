{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "automerge": true,
  "docker-compose": {
    "managerFilePatterns": [
      "/(^|/)docker-compose\\.ya?ml$/",
      "/(^|/)compose\\.ya?ml$/",
      "/\\.ya?ml\\.j2$/"
    ]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "matchPackageNames": ["postgres"],
      "automerge": false
    }
  ]
}
